{
  "name": "wasmemit",
  "version": "0.0.0",
  "description": "A JavaScript module for generating WebAssembly modules using expression builders",
  "type": "module",
  "main": "src/index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./src/index.js"
    }
  },
  "scripts": {
    "test": "node --test 'test/**/*.test.js'",
    "types": "node scripts/generate-dts.js"
  },
  "keywords": [
    "webassembly",
    "wasm",
    "codegen",
    "compiler",
    "expression-builder"
  ],
  "author": "Bryon Vandiver <unicdk@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asterick/wasmemit.git"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "src",
    "index.d.ts"
  ]
}
